# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Image model (each has its own quota; if you see limit:0 / quota errors, switch model or enable billing):
# Default in code is Nano Banana Pro unless you override:
# Nano Banana Pro (preview):     gemini-3-pro-image-preview
# Nano Banana 2 (preview):       gemini-3.1-flash-image-preview
# Nano Banana (fast):            gemini-2.5-flash-image
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Output resolution for image models (when API accepts it): 1K | 2K | 4K
GEMINI_IMAGE_SIZE=2K

# Optional: bind (Render sets PORT)
# PORT=3000
